#!/bin/bash
# Auto-generated veRL training launcher
# Experiment: {{ config.experiment.name }}
# Generated by FineTuning-Envelope

set -e

echo "Starting veRL training for {{ config.training.technique.value }}"

# Export hyperparameters
export LEARNING_RATE="{{ config.hparam_overrides.get('learning_rate', 1e-5) }}"
export BATCH_SIZE="{{ config.hparam_overrides.get('per_device_train_batch_size', 2) }}"
export EPOCHS="{{ config.hparam_overrides.get('num_train_epochs', 3) }}"
export GRADIENT_ACCUMULATION="{{ config.hparam_overrides.get('gradient_accumulation_steps', 4) }}"

# Model and data paths
MODEL_PATH="{{ config.model.name_or_path }}"
DATA_PATH="{{ config.dataset.path }}"
OUTPUT_DIR="{{ config.output.dir }}"

# Create output directory
mkdir -p "$OUTPUT_DIR"

# veRL launcher command based on technique
case "{{ config.training.technique.value }}" in
  ppo|grpo|dapo|vapo|rloo|reinforce_pp|dr_grpo)
    echo "Launching {{ config.training.technique.value }} RL training..."
    verl_launcher \
      --model_path "$MODEL_PATH" \
      --data_path "$DATA_PATH" \
      --output_dir "$OUTPUT_DIR" \
      --learning_rate "$LEARNING_RATE" \
      --per_device_batch_size "$BATCH_SIZE" \
      --num_epochs "$EPOCHS" \
      --technique "{{ config.training.technique.value }}" \
      {% if config.optimization.gradient_checkpointing %}--gradient_checkpointing{% endif %} \
      {% if config.training.precision.compute_dtype.value == "bf16" %}--bf16{% endif %}
    ;;
  *)
    echo "Error: veRL does not support technique '{{ config.training.technique.value }}'"
    exit 1
    ;;
esac

echo "Training complete. Outputs saved to $OUTPUT_DIR"
