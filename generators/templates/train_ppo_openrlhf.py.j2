#!/usr/bin/env python3
"""
Auto-generated training script: {{ config.training.technique.value | upper }} via OpenRLHF
Experiment: {{ config.experiment.name }}
Generated by FineTuning-Envelope
"""
import json
import os

from openrlhf.trainer import OpenRLFTrainer
from prepare import get_train_dataset, get_eval_dataset, get_tokenizer
from shared_utils import resolve_hyperparams

# ──────────────── Hyperparameter Resolution ────────────────

HYPERPARAM_DEFAULTS = {
{% for key, value in hparam_defaults.items() %}
{% if value is string %}
    "{{ key }}": "{{ value }}",
{% else %}
    "{{ key }}": {{ value }},
{% endif %}
{% endfor %}
}


hparams = resolve_hyperparams(HYPERPARAM_DEFAULTS)

# ──────────────── Structured Output ────────────────

STRUCTURED = os.environ.get("ENVELOPE_STRUCTURED_OUTPUT", "false").lower() == "true"
RUN_ID = os.environ.get("RUN_ID", "standalone")


def emit(marker: str, data):
    if STRUCTURED:
        if isinstance(data, dict):
            print(f"{marker}: {json.dumps(data)}", flush=True)
        else:
            print(f"{marker}: {data}", flush=True)


emit("EXPERIMENT_STATUS", "STARTED")
emit("EXPERIMENT_RUN_ID", RUN_ID)
emit("EXPERIMENT_HYPERPARAMS", hparams)

# ──────────────── Model and Data ────────────────

print(f"Loading model: {{ config.model.name_or_path }}")
model = type(
    "OpenRLHFModel",
    (),
    {"name": "{{ config.model.name_or_path }}", "technique": "{{ config.training.technique.value }}"}
)()

tokenizer = get_tokenizer()
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token

train_dataset = get_train_dataset()
eval_dataset = get_eval_dataset()

# ──────────────── Trainer Setup ────────────────

print("Initializing OpenRLHF trainer...")
trainer = OpenRLFTrainer(
    model=model,
    tokenizer=tokenizer,
    train_dataset=train_dataset,
    eval_dataset=eval_dataset,
    args={
        "technique": "{{ config.training.technique.value }}",
        "learning_rate": hparams["learning_rate"],
        "batch_size": int(hparams["per_device_train_batch_size"]),
        "epochs": int(hparams["num_train_epochs"]),
        "gradient_accumulation_steps": int(hparams["gradient_accumulation_steps"]),
        "output_dir": "{{ config.output.dir }}",
        "logging_steps": {{ config.output.logging_steps }},
        "seed": {{ config.experiment.seed }},
    },
)

# ──────────────── Training ────────────────

try:
    print("Starting OpenRLHF training...")
    metrics = trainer.train()
    emit("EXPERIMENT_RESULT", metrics)
    emit("EXPERIMENT_STATUS", "COMPLETED")
    print(f"Training complete. Model saved to {{ config.output.dir }}")
except Exception as e:
    emit("EXPERIMENT_STATUS", f"CRASHED: {e}")
    raise
