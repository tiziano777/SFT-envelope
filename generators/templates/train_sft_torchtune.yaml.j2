# Auto-generated TorchTune training recipe
# Experiment: {{ config.experiment.name }}
# Generated by FineTuning-Envelope

# Model configuration
model:
  _target_: torchtune.models.{{ config.model.name_or_path.split('/')[-1].lower() }}

# Tokenizer configuration
tokenizer:
  _target_: torchtune.models.utils.get_tokenizer
  path: {{ config.model.name_or_path }}

# Dataset configuration
dataset:
  _target_: torchtune.datasets.instruct_dataset
  source: {{ config.dataset.path }}
  split: train

# Training configuration
training:
  _target_: torchtune.training.TrainingConfig
  epochs: {{ config.hparam_overrides.get("num_train_epochs", 3) }}
  max_steps_per_epoch: null
  log_every_n_steps: {{ config.output.logging_steps }}
  save_every_n_steps: {{ config.output.save_steps }}
  log_peak_memory_stats: false
  enable_activation_checkpointing: {{ config.optimization.gradient_checkpointing | lower }}

# Optimizer configuration
optimizer:
  _target_: torch.optim.AdamW
  lr: {{ config.hparam_overrides.get("learning_rate", 1e-5) }}
  weight_decay: {{ config.hparam_overrides.get("weight_decay", 0.01) }}

# Loss configuration
loss:
  _target_: torch.nn.CrossEntropyLoss

# Batch configuration
batch_size: {{ config.hparam_overrides.get("per_device_train_batch_size", 2) }}
gradient_accumulation_steps: {{ config.hparam_overrides.get("gradient_accumulation_steps", 4) }}

# Output configuration
output_dir: {{ config.output.dir }}
checkpoint_dir: null
device: cuda
mixed_precision: {{ config.training.precision.compute_dtype.value }}

{% if config.training.peft.method.value != "none" %}
# PEFT (LoRA) configuration
peft:
  lora_rank: {{ config.training.peft.r }}
  lora_alpha: {{ config.training.peft.lora_alpha }}
  lora_dropout: {{ config.training.peft.lora_dropout }}
{% endif %}

# Seed for reproducibility
seed: {{ config.experiment.seed }}
