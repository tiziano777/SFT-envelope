# Auto-generated Axolotl training configuration
# Experiment: {{ config.experiment.name }}
# Generated by FineTuning-Envelope

base_model: {{ config.model.name_or_path }}
model_type: LlamaForCausalLM
tokenizer_type: LlamaTokenizer

# Dataset
dataset:
  - path: {{ config.dataset.path }}
    type: alpaca
    split: train

eval_dataset:
  - path: {{ config.dataset.path }}
    type: alpaca
    split: validation

# Training hyperparameters
num_epochs: {{ config.hparam_overrides.get("num_train_epochs", 3) }}
per_device_train_batch_size: {{ config.hparam_overrides.get("per_device_train_batch_size", 2) }}
per_device_eval_batch_size: 4
gradient_accumulation_steps: {{ config.hparam_overrides.get("gradient_accumulation_steps", 4) }}
learning_rate: {{ config.hparam_overrides.get("learning_rate", 1e-5) }}
lr_scheduler_type: {{ config.hparam_overrides.get("lr_scheduler_type", "cosine") }}
warmup_ratio: {{ config.hparam_overrides.get("warmup_ratio", 0.1) }}
weight_decay: {{ config.hparam_overrides.get("weight_decay", 0.01) }}
max_grad_norm: {{ config.hparam_overrides.get("max_grad_norm", 1.0) }}

# Optimization
optim: adamw_torch
{% if config.optimization.gradient_checkpointing %}
gradient_checkpointing: true
{% endif %}
{% if config.training.precision.compute_dtype.value == "bf16" %}
bf16: true
{% elif config.training.precision.compute_dtype.value == "fp16" %}
fp16: true
{% endif %}

# Output
output_dir: {{ config.output.dir }}
logging_steps: {{ config.output.logging_steps }}
save_steps: {{ config.output.save_steps }}
save_total_limit: {{ config.output.save_total_limit }}

# Evaluation
eval_steps: null
eval_strategy: "no"

{% if config.training.peft.method.value != "none" %}
# PEFT configuration
adapter: lora
lora_r: {{ config.training.peft.r }}
lora_alpha: {{ config.training.peft.lora_alpha }}
lora_dropout: {{ config.training.peft.lora_dropout }}
lora_target_modules: {{ config.training.peft.target_modules | tojson }}
{% endif %}

# Seed
seed: {{ config.experiment.seed }}
