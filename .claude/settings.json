{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(python -m pytest *)",
      "Bash(python -m src.shared.env_validation)",
      "Bash(ruff *)",
      "Bash(docker compose *)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(*> .env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "command": "code-review-graph update --skip-flows",
        "timeout": 5000
      }
    ],
    "SessionStart": [
      {
        "command": "code-review-graph status",
        "timeout": 3000
      }
    ],
    "PreCommit": [
      {
        "command": "code-review-graph detect-changes --brief",
        "timeout": 10000
      }
    ]
  },
  "skills": [
    "./.claude/skills/caveman",
    "./.claude/skills/caveman-review"
  ]
}
